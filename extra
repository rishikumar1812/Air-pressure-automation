def read_latest_dfile(files):

    rows = []

    current = {}

    for file in files:
        with open(file, "r") as f:
            for line in f:
                line = line.strip()

                if line.startswith("MODEL"):
                    current["modelname"] = line.split(":")[1].strip()

                elif line.startswith("START TEMP"):
                    current["Start Temp"] = int(line.split(":")[1].strip())

                elif line.startswith("END TEMP"):
                    current["End Temp"] = int(line.split(":")[1].strip())

                elif line.startswith("UPDATE TIME"):
                    current["Update Time"] = line.split(":")[1].strip()

                    # 🔥 ROW COMPLETE → SAVE
                    if all(k in current for k in ["modelname", "Start Temp", "End Temp", "Update Time"]):
                        rows.append(current)

                    # reset for next row
                    current = {}

    if not rows:
        return None

    return pd.DataFrame(rows)